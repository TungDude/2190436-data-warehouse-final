aws_region  = "ap-southeast-1"
aws_profile = "data-warehouse-final"

# Keep this spelling unless the project convention changes.
raw_chicago_crime_prefix = "raw/chicaho_crime"

# ---------------------------------------------------------------------------
# Silver / Glue overrides (defaults are sensible; uncomment only to override).
# ---------------------------------------------------------------------------

# silver_prefix       = "standardized"
# glue_scripts_prefix = "glue/scripts"

# glue_workflow_schedule_expression = "cron(30 3 * * ? *)"
# glue_workflow_schedule_timezone   = "America/Chicago"
# glue_workflow_schedule_enabled    = true

# Add additional source names here as their handler modules land
# under src/glue_jobs/bronze_to_silver/sources/.
# glue_supported_sources = ["chicago_crime"]

# ---------------------------------------------------------------------------
# QuickSight BI layer.
#
# Enable only after the account is subscribed to QuickSight in aws_region.
# The principal ARN is the QuickSight author/user or group that should own the
# data source, dataset, and dashboards.
# ---------------------------------------------------------------------------

# quicksight_enabled = true
# quicksight_admin_principal_arn = "arn:aws:quicksight:ap-southeast-1:238027390687:user/default/<username>"
# quicksight_refresh_time = "04:30"           # one hour after gold Glue workflow start
# quicksight_refresh_timezone = "America/Chicago"

# ---------------------------------------------------------------------------
# Pause toggles — flip all three to `false` to disable all recurring
# AWS-side schedules (Lambda fetch, Glue workflow, QuickSight SPICE refresh)
# without destroying any infrastructure. The QuickSight refresh schedule
# resource is gated on its flag (count = ... ? 1 : 0), so toggling it off
# removes the schedule object and toggling back recreates it. See
# docs/pause-log.md for the full pause/resume runbook used 2026-05-16.
# ---------------------------------------------------------------------------

# fetch_schedule_enabled         = true
# glue_workflow_schedule_enabled = true
# quicksight_refresh_enabled     = true
